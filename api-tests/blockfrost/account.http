
### @name getAccountInfoBlockfrost
### Get account info from Blockfrost
GET {{blockfrost_base_url}}/accounts/{{test_stake_address}}
project_id: {{blockfrost_project_id}}

> {%
    client.global.set("bfAccountInfo", response.body);

    client.test("Get account info from Blockfrost", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### @name getAccountInfoYaci
### Get account info from Yaci Store
GET {{base_url}}/api/v1/blockfrost/accounts/{{test_stake_address}}

> {%
    const bfResponse = client.global.get("bfAccountInfo");
    const yaciResponse = response.body;

    client.test("Compare account info between Blockfrost and Yaci", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(bfResponse.stake_address === yaciResponse.stake_address, `stake_address mismatch`);
        client.assert(bfResponse.active === yaciResponse.active, `active mismatch`);
        client.assert(bfResponse.pool_id === yaciResponse.pool_id, `pool_id mismatch`);
    });
%}

