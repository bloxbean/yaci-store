### @name getAccountDelegationsBlockfrost
### Get account delegations from Blockfrost
GET {{blockfrost_base_url}}/accounts/{{test_stake_address}}/delegations?count=5
project_id: {{blockfrost_project_id}}

> {%
    client.global.set("bfAccountDelegations", response.body);
    client.test("Get account delegations from Blockfrost", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### @name getAccountDelegationsYaci
### Get account delegations from Yaci Store
GET {{base_url}}/api/v1/blockfrost/accounts/{{test_stake_address}}/delegations?count=5

> {%
    const bfResponse = client.global.get("bfAccountDelegations");
    const yaciResponse = response.body;

    client.test("Compare account delegations between Blockfrost and Yaci", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(Array.isArray(yaciResponse), "Response should be an array");
        if (bfResponse.length > 0 && yaciResponse.length > 0) {
            client.assert(bfResponse[0].tx_hash === yaciResponse[0].tx_hash, `First delegation tx_hash mismatch`);
            client.assert(bfResponse[0].pool_id === yaciResponse[0].pool_id, `First delegation pool_id mismatch`);
        }
    });
%}

