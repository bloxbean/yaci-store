###

### @name getErasYaci
### Fetch era summaries from Yaci Store and validate structure
GET {{base_url}}/api/v1/blockfrost/network/eras

> {%
    const bf   = client.global.get("blockfrostErasResponse");
    const yaci = response.body;

    client.test("Yaci /network/eras: HTTP 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.test("Yaci /network/eras: response is an array", function() {
        client.assert(Array.isArray(yaci), "Response must be an array, got " + typeof yaci);
    });

    client.test("Yaci /network/eras: at least one era returned", function() {
        client.assert(yaci.length > 0, "Era list is empty — Byron era should always be present");
    });

    // ── Validate structure of each era ───────────────────────────────────────
    yaci.forEach(function(era, index) {
        const prefix = "era[" + index + "]";

        client.test(prefix + ".start is present", function() {
            client.assert(era.start !== undefined, prefix + ".start is missing");
        });

        client.test(prefix + ".start.slot is a number", function() {
            client.assert(typeof era.start.slot === "number",
                prefix + ".start.slot must be number, got " + typeof era.start.slot);
        });

        client.test(prefix + ".start.time is a number", function() {
            client.assert(typeof era.start.time === "number",
                prefix + ".start.time must be number, got " + typeof era.start.time);
        });

        client.test(prefix + ".start.epoch is a number", function() {
            client.assert(typeof era.start.epoch === "number",
                prefix + ".start.epoch must be number, got " + typeof era.start.epoch);
        });

        client.test(prefix + ".parameters is present", function() {
            client.assert(era.parameters !== undefined, prefix + ".parameters is missing");
        });

        client.test(prefix + ".parameters.epoch_length > 0", function() {
            client.assert(era.parameters.epoch_length > 0,
                prefix + ".parameters.epoch_length must be > 0");
        });

        client.test(prefix + ".parameters.slot_length > 0", function() {
            client.assert(era.parameters.slot_length > 0,
                prefix + ".parameters.slot_length must be > 0");
        });

        client.test(prefix + ".parameters.safe_zone >= 0", function() {
            client.assert(era.parameters.safe_zone >= 0,
                prefix + ".parameters.safe_zone must be >= 0");
        });
    });

    // ── First era should be Byron (slot 0, epoch 0) ──────────────────────────
    client.test("First era starts at slot 0 (Byron)", function() {
        client.assert(yaci[0].start.slot === 0,
            "First era start.slot should be 0 (Byron), got " + yaci[0].start.slot);
    });

    client.test("First era starts at epoch 0", function() {
        client.assert(yaci[0].start.epoch === 0,
            "First era start.epoch should be 0, got " + yaci[0].start.epoch);
    });

    // ── Compare with Blockfrost era count ────────────────────────────────────
    if (bf && Array.isArray(bf)) {
        client.test("Era count matches Blockfrost", function() {
            client.assert(yaci.length === bf.length,
                "Era count mismatch — BF: " + bf.length + ", Yaci: " + yaci.length);
        });
    }
%}

