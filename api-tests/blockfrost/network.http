###

### @name getNetworkYaci
### Fetch network info from Yaci Store and validate Blockfrost compatibility
GET {{base_url}}/api/v1/blockfrost/network

> {%
    const bf   = client.global.get("blockfrostNetworkResponse");
    const yaci = response.body;

    // ── HTTP status ─────────────────────────────────────────────────────────
    client.test("Yaci /network: HTTP 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    // ── Structure: top-level keys ────────────────────────────────────────────
    client.test("Yaci /network: supply object present", function() {
        client.assert(yaci.supply !== undefined, "supply object is missing");
    });

    client.test("Yaci /network: stake object present", function() {
        client.assert(yaci.stake !== undefined, "stake object is missing");
    });

    // ── CRITICAL: ALL numeric fields must be STRING (not number) ─────────────
    client.test("CRITICAL supply.max is a String", function() {
        client.assert(typeof yaci.supply.max === "string",
            "supply.max must be STRING, got " + typeof yaci.supply.max + " (" + yaci.supply.max + ")");
    });

    client.test("CRITICAL supply.circulating is a String", function() {
        client.assert(typeof yaci.supply.circulating === "string",
            "supply.circulating must be STRING, got " + typeof yaci.supply.circulating);
    });

    client.test("CRITICAL supply.treasury is a String", function() {
        client.assert(typeof yaci.supply.treasury === "string",
            "supply.treasury must be STRING, got " + typeof yaci.supply.treasury);
    });

    client.test("CRITICAL supply.reserves is a String", function() {
        client.assert(typeof yaci.supply.reserves === "string",
            "supply.reserves must be STRING, got " + typeof yaci.supply.reserves);
    });

    client.test("CRITICAL stake.active is a String", function() {
        client.assert(typeof yaci.stake.active === "string",
            "stake.active must be STRING, got " + typeof yaci.stake.active);
    });

    // ── CRITICAL: Derived fields that Blockfrost requires ────────────────────
    client.test("CRITICAL supply.total is present", function() {
        client.assert(yaci.supply.total !== undefined && yaci.supply.total !== null,
            "supply.total is missing — required by Blockfrost");
    });

    client.test("CRITICAL supply.total is a String", function() {
        client.assert(typeof yaci.supply.total === "string",
            "supply.total must be STRING, got " + typeof yaci.supply.total);
    });

    client.test("CRITICAL supply.locked is present", function() {
        client.assert(yaci.supply.locked !== undefined && yaci.supply.locked !== null,
            "supply.locked is missing — required by Blockfrost");
    });

    client.test("CRITICAL supply.locked is a String", function() {
        client.assert(typeof yaci.supply.locked === "string",
            "supply.locked must be STRING, got " + typeof yaci.supply.locked);
    });

    client.test("CRITICAL stake.live is present", function() {
        client.assert(yaci.stake.live !== undefined && yaci.stake.live !== null,
            "stake.live is missing — required by Blockfrost");
    });

    client.test("CRITICAL stake.live is a String", function() {
        client.assert(typeof yaci.stake.live === "string",
            "stake.live must be STRING, got " + typeof yaci.stake.live);
    });

    // ── Values exceed JavaScript MAX_SAFE_INTEGER (9007199254740991) ─────────
    client.test("supply.max value is plausible ADA max supply", function() {
        const max = BigInt(yaci.supply.max);
        client.assert(max > 0n, "supply.max must be > 0");
        client.assert(max <= 45000000000000000n, "supply.max must be <= 45B ADA in lovelace");
    });

    // ── supply.total = supply.max - supply.reserves ──────────────────────────
    client.test("supply.total = supply.max - supply.reserves", function() {
        const max      = BigInt(yaci.supply.max);
        const reserves = BigInt(yaci.supply.reserves);
        const total    = BigInt(yaci.supply.total);
        client.assert(total === max - reserves,
            "supply.total (" + yaci.supply.total + ") != max (" + yaci.supply.max + ") - reserves (" + yaci.supply.reserves + ")");
    });

    // ── Compare with Blockfrost (only if Blockfrost call succeeded) ───────────
    if (bf && bf.supply) {
        client.test("supply.max matches Blockfrost", function() {
            client.assert(yaci.supply.max === bf.supply.max,
                "supply.max mismatch — BF: " + bf.supply.max + ", Yaci: " + yaci.supply.max);
        });
    }
%}

