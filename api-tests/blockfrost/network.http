###

### @name getGenesisYaci
### Fetch genesis from Yaci Store and validate structure
GET {{base_url}}/api/v1/blockfrost/genesis

> {%
    const bf   = client.global.get("blockfrostGenesisResponse");
    const yaci = response.body;

    client.test("Yaci /genesis: HTTP 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    // ── Required fields ──────────────────────────────────────────────────────
    const requiredFields = [
        "active_slots_coefficient",
        "update_quorum",
        "max_lovelace_supply",
        "network_magic",
        "epoch_length",
        "system_start",
        "slots_per_kes_period",
        "slot_length",
        "max_kes_evolutions",
        "security_param"
    ];

    requiredFields.forEach(function(field) {
        client.test("genesis field '" + field + "' is present", function() {
            client.assert(yaci[field] !== undefined && yaci[field] !== null,
                "Required field '" + field + "' is missing or null");
        });
    });

    // ── CRITICAL: max_lovelace_supply must be a String ───────────────────────
    client.test("CRITICAL genesis.max_lovelace_supply is a String", function() {
        client.assert(typeof yaci.max_lovelace_supply === "string",
            "max_lovelace_supply must be STRING, got " + typeof yaci.max_lovelace_supply);
    });

    // ── Value sanity checks ──────────────────────────────────────────────────
    client.test("genesis.active_slots_coefficient is a valid fraction (0 < f <= 1)", function() {
        const f = yaci.active_slots_coefficient;
        client.assert(typeof f === "number", "active_slots_coefficient must be a number");
        client.assert(f > 0 && f <= 1, "active_slots_coefficient out of range: " + f);
    });

    client.test("genesis.epoch_length > 0", function() {
        client.assert(yaci.epoch_length > 0, "epoch_length must be > 0");
    });

    client.test("genesis.system_start is a valid Unix timestamp (> 2017)", function() {
        // Cardano mainnet launched Sept 2017 = 1504224000
        client.assert(yaci.system_start > 1504224000, "system_start looks wrong: " + yaci.system_start);
    });

    client.test("genesis.security_param > 0", function() {
        client.assert(yaci.security_param > 0, "security_param must be > 0");
    });

    client.test("genesis.slot_length = 1 (Shelley slot = 1 second)", function() {
        client.assert(yaci.slot_length === 1, "slot_length should be 1, got " + yaci.slot_length);
    });

    // ── Compare with Blockfrost ──────────────────────────────────────────────
    if (bf) {
        client.test("genesis.max_lovelace_supply matches Blockfrost", function() {
            client.assert(yaci.max_lovelace_supply === bf.max_lovelace_supply,
                "max_lovelace_supply mismatch — BF: " + bf.max_lovelace_supply + ", Yaci: " + yaci.max_lovelace_supply);
        });

        client.test("genesis.epoch_length matches Blockfrost", function() {
            client.assert(yaci.epoch_length === bf.epoch_length,
                "epoch_length mismatch — BF: " + bf.epoch_length + ", Yaci: " + yaci.epoch_length);
        });

        client.test("genesis.security_param matches Blockfrost", function() {
            client.assert(yaci.security_param === bf.security_param,
                "security_param mismatch — BF: " + bf.security_param + ", Yaci: " + yaci.security_param);
        });

        client.test("genesis.active_slots_coefficient matches Blockfrost", function() {
            client.assert(yaci.active_slots_coefficient === bf.active_slots_coefficient,
                "active_slots_coefficient mismatch — BF: " + bf.active_slots_coefficient + ", Yaci: " + yaci.active_slots_coefficient);
        });
    }
%}

