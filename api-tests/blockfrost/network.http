### @name getRootYaci
GET {{base_url}}/api/v1/blockfrost/

> {%
    const yaci = response.body;

    client.test("Yaci /: HTTP 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });

    client.test("Yaci /: url field is present", function() {
        client.assert(yaci.url !== undefined, "'url' field missing");
    });

    client.test("Yaci /: version field is present", function() {
        client.assert(yaci.version !== undefined, "'version' field missing");
    });

    client.test("Yaci /: url is a non-empty string", function() {
        client.assert(typeof yaci.url === "string" && yaci.url.length > 0,
            "'url' must be a non-empty string");
    });

    client.test("Yaci /: version is a non-empty string", function() {
        client.assert(typeof yaci.version === "string" && yaci.version.length > 0,
            "'version' must be a non-empty string");
    });
%}

