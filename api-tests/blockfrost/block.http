### @name getLatestBlockTxsCborBlockfrost
### Get latest block txs with cbor from Blockfrost
GET {{blockfrost_base_url}}/blocks/latest/txs/cbor?count=20&page=1&order=asc
project_id: {{blockfrost_project_id}}

> {%
    client.global.set("bfLatestTxsCbor", response.body);
    client.global.set("bfLatestTxsCborStatus", response.status);

    client.test("Blockfrost latest txs cbor request", function() {
        client.assert(response.status === 200 || response.status === 404, "Unexpected status");
    });
%}

### @name getLatestBlockTxsCborYaci
### Get latest block txs with cbor from Yaci and compare
# @timeout 6000
GET {{base_url}}/api/v1/blockfrost/blocks/latest/txs/cbor?count=20&page=1&order=asc

> {%
    const bfStatus = client.global.get("bfLatestTxsCborStatus");
    const bf = client.global.get("bfLatestTxsCbor");

    client.test("Compare latest block tx cbor between Blockfrost and Yaci", function() {
        if (response.status === 404) {
            client.assert(response.body.message === "The requested component has not been found.", "Unexpected 404 message");
            return;
        }

        client.assert(response.status === bfStatus, `status mismatch (Blockfrost: ${bfStatus}, Yaci: ${response.status})`);

        const yaci = response.body;
        client.assert(Array.isArray(yaci), "Yaci response should be an array");

        if (Array.isArray(bf)) {
            client.assert(bf.length === yaci.length, `array length mismatch (Blockfrost: ${bf.length}, Yaci: ${yaci.length})`);
            if (bf.length > 0 && yaci.length > 0) {
                client.assert(bf[0].tx_hash === yaci[0].tx_hash, `first tx hash mismatch (Blockfrost: ${bf[0].tx_hash}, Yaci: ${yaci[0].tx_hash})`);
            }
        }
    });
%}

