
### @name getLatestBlockBlockfrost
### Get latest block from Blockfrost
GET {{blockfrost_base_url}}/blocks/latest
project_id: {{blockfrost_project_id}}

> {%
    client.global.set("bfLatestBlock", response.body);
    client.global.set("bfLatestBlockStatus", response.status);

    if (response.status === 200 && response.body) {
        client.global.set("bfLatestHash", response.body.hash);
        client.global.set("bfLatestHeight", response.body.height);
        client.global.set("bfLatestSlot", response.body.slot);
        client.global.set("bfLatestEpoch", response.body.epoch);
        client.global.set("bfLatestPrevHash", response.body.previous_block);

        const nextAnchor = response.body.previous_block ? response.body.previous_block : response.body.hash;
        client.global.set("bfNextAnchor", nextAnchor);
    }

    client.test("Blockfrost latest block request", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
%}

### @name getLatestBlockYaci
### Get latest block from Yaci and compare
# @timeout 6000
GET {{base_url}}/api/v1/blockfrost/blocks/latest

> {%
    const bf = client.global.get("bfLatestBlock");
    const yaci = response.body;

    client.test("Compare latest block between Blockfrost and Yaci", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(bf.hash === yaci.hash, `hash mismatch (Blockfrost: ${bf.hash}, Yaci: ${yaci.hash})`);
        client.assert(bf.height === yaci.height, `height mismatch (Blockfrost: ${bf.height}, Yaci: ${yaci.height})`);
        client.assert(bf.slot === yaci.slot, `slot mismatch (Blockfrost: ${bf.slot}, Yaci: ${yaci.slot})`);
        client.assert(bf.epoch === yaci.epoch, `epoch mismatch (Blockfrost: ${bf.epoch}, Yaci: ${yaci.epoch})`);
        client.assert(bf.tx_count === yaci.tx_count, `tx_count mismatch (Blockfrost: ${bf.tx_count}, Yaci: ${yaci.tx_count})`);
        client.assert(bf.output === yaci.output, `output mismatch (Blockfrost: ${bf.output}, Yaci: ${yaci.output})`);
        client.assert(bf.fees === yaci.fees, `fees mismatch (Blockfrost: ${bf.fees}, Yaci: ${yaci.fees})`);
        client.assert(bf.previous_block === yaci.previous_block, `previous_block mismatch (Blockfrost: ${bf.previous_block}, Yaci: ${yaci.previous_block})`);
    });
%}

