### @name getBlockAddressesBlockfrost
### Get affected addresses for specific block from Blockfrost
GET {{blockfrost_base_url}}/blocks/{{bfLatestHash}}/addresses?count=20&page=1
project_id: {{blockfrost_project_id}}

> {%
    client.global.set("bfBlockAddresses", response.body);
    client.global.set("bfBlockAddressesStatus", response.status);

    client.test("Blockfrost block addresses request", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(Array.isArray(response.body), "Response should be an array");
    });
%}

### @name getBlockAddressesYaci
### Get affected addresses for specific block from Yaci and compare
# @timeout 6000
GET {{base_url}}/api/v1/blockfrost/blocks/{{bfLatestHash}}/addresses?count=20&page=1

> {%
    const bf = client.global.get("bfBlockAddresses");
    const yaci = response.body;

    client.test("Compare block addresses between Blockfrost and Yaci", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(Array.isArray(yaci), "Yaci response should be an array");
        client.assert(bf.length === yaci.length, `array length mismatch (Blockfrost: ${bf.length}, Yaci: ${yaci.length})`);

        if (bf.length > 0 && yaci.length > 0) {
            client.assert(bf[0].address === yaci[0].address, `first address mismatch (Blockfrost: ${bf[0].address}, Yaci: ${yaci[0].address})`);

            const bfTxs = Array.isArray(bf[0].transactions) ? bf[0].transactions : [];
            const yaciTxs = Array.isArray(yaci[0].transactions) ? yaci[0].transactions : [];
            client.assert(bfTxs.length === yaciTxs.length, `first address tx count mismatch (Blockfrost: ${bfTxs.length}, Yaci: ${yaciTxs.length})`);

            if (bfTxs.length > 0 && yaciTxs.length > 0) {
                client.assert(bfTxs[0].tx_hash === yaciTxs[0].tx_hash,
                    `first tx hash mismatch (Blockfrost: ${bfTxs[0].tx_hash}, Yaci: ${yaciTxs[0].tx_hash})`);
            }
        }
    });
%}
