### @name getNextBlocksBlockfrost
### Get next blocks from Blockfrost
GET {{blockfrost_base_url}}/blocks/{{bfNextAnchor}}/next?count=5&page=1
project_id: {{blockfrost_project_id}}

> {%
    client.global.set("bfNextBlocks", response.body);
    client.global.set("bfNextBlocksStatus", response.status);

    client.test("Blockfrost next blocks request", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(Array.isArray(response.body), "Response should be an array");
    });
%}

### @name getNextBlocksYaci
### Get next blocks from Yaci and compare
# @timeout 6000
GET {{base_url}}/api/v1/blockfrost/blocks/{{bfNextAnchor}}/next?count=5&page=1

> {%
    const bf = client.global.get("bfNextBlocks");
    const yaci = response.body;

    client.test("Compare next blocks between Blockfrost and Yaci", function() {
        client.assert(response.status === 200, "Response status is not 200");
        client.assert(Array.isArray(yaci), "Yaci response should be an array");
        client.assert(bf.length === yaci.length, `array length mismatch (Blockfrost: ${bf.length}, Yaci: ${yaci.length})`);

        if (bf.length > 0 && yaci.length > 0) {
            client.assert(bf[0].hash === yaci[0].hash, `first hash mismatch (Blockfrost: ${bf[0].hash}, Yaci: ${yaci[0].hash})`);
            client.assert(bf[0].height === yaci[0].height, `first height mismatch (Blockfrost: ${bf[0].height}, Yaci: ${yaci[0].height})`);
        }
    });
%}

